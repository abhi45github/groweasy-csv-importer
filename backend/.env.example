# ─────────────────────────────────────────────────────────────
#  GrowEasy CSV Importer — Backend environment
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins for the frontend.
# Use * to allow all (fine for local dev / public demo).
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────
#  AI provider configuration
#  The backend auto-selects a provider based on AI_PROVIDER, or
#  falls back to whichever API key is present. If no key is found,
#  it uses a deterministic heuristic mapper so the app still works.
# ─────────────────────────────────────────────────────────────

# One of: gemini | openai | anthropic | auto   (default: auto)
AI_PROVIDER=auto

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ─────────────────────────────────────────────────────────────
#  Extraction tuning
# ─────────────────────────────────────────────────────────────

# Rows sent to the LLM per request
AI_BATCH_SIZE=25

# How many batches run concurrently
AI_CONCURRENCY=3

# Retry attempts per failed batch (exponential backoff)
AI_MAX_RETRIES=3

# Max rows accepted from a single upload (guardrail)
MAX_ROWS=5000

# Max upload size in megabytes
MAX_UPLOAD_MB=10
