# ─────────────────────────────────────────────────────────────
#  Root env used by docker-compose. Copy to `.env` and fill in a key.
#  (Each app also has its own .env.example for standalone local dev.)
# ─────────────────────────────────────────────────────────────

# One of: auto | gemini | openai | anthropic
AI_PROVIDER=auto

# Provide at least ONE of the following for real AI extraction.
# With none set, the app still works using the heuristic mapper.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Extraction tuning
AI_BATCH_SIZE=25
AI_CONCURRENCY=3
